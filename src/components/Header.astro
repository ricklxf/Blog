---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/tags">Tags</HeaderLink>
			<HeaderLink href="/search">Search</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
		<div class="right-area">
			<a href="/rss.xml" class="rss-link" title="RSS Feed" aria-label="RSS Feed">
				<svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
					<path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/>
				</svg>
			</a>
			<button id="theme-toggle" aria-label="Toggle dark mode">
				<span class="toggle-track">
					<span class="toggle-thumb"></span>
					<svg class="sun-icon" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
						<circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
					</svg>
					<svg class="moon-icon" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
						<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
					</svg>
				</span>
			</button>
		</div>
	</nav>
</header>

<script>
	const toggle = document.getElementById('theme-toggle');
	function applyTheme(theme: string) {
		document.documentElement.setAttribute('data-theme', theme);
		localStorage.setItem('theme', theme);
	}
	toggle?.addEventListener('click', () => {
		const current = document.documentElement.getAttribute('data-theme');
		applyTheme(current === 'dark' ? 'light' : 'dark');
	});
</script>

<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: var(--header-bg);
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
		position: sticky;
		top: 0;
		z-index: 100;
	}

	h2 {
		margin: 0;
		font-size: 1em;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
		color: rgb(var(--black));
	}

	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1em;
		height: 56px;
	}

	nav a {
		padding: 0.4em 0.7em;
		color: var(--text-muted);
		border-bottom: none;
		text-decoration: none;
		font-size: 0.95em;
		border-radius: 6px;
		transition: color 0.15s, background 0.15s;
	}

	nav a:hover {
		color: var(--accent);
		background: var(--bg-secondary);
	}

	nav a.active {
		color: var(--accent);
		background: color-mix(in srgb, var(--accent) 10%, transparent);
		font-weight: 600;
	}

	.internal-links {
		display: flex;
		gap: 0.1em;
	}

	.right-area {
		display: flex;
		align-items: center;
		gap: 0.5em;
	}

	.rss-link {
		color: rgb(var(--gray));
		border-bottom: none !important;
		display: flex;
		align-items: center;
		padding: 0.4em;
		border-radius: 6px;
	}

	.rss-link:hover {
		color: var(--accent);
		background: var(--bg-secondary);
	}

	#theme-toggle {
		background: none;
		border: none;
		cursor: pointer;
		padding: 0;
		display: flex;
		align-items: center;
	}

	.toggle-track {
		position: relative;
		display: flex;
		align-items: center;
		width: 52px;
		height: 28px;
		background: #c8cdd8;
		border-radius: 999px;
		transition: background 0.25s;
		padding: 0 7px;
		justify-content: space-between;
	}

	[data-theme='dark'] .toggle-track {
		background: var(--accent);
	}

	.toggle-thumb {
		position: absolute;
		left: 3px;
		width: 22px;
		height: 22px;
		background: white;
		border-radius: 50%;
		box-shadow: 0 1px 4px rgba(0,0,0,0.2);
		transition: left 0.25s;
	}

	[data-theme='dark'] .toggle-thumb {
		left: calc(100% - 25px);
	}

	.sun-icon {
		color: #f5a623;
		position: relative;
		z-index: 1;
	}

	.moon-icon {
		color: white;
		position: relative;
		z-index: 1;
	}

	@media (max-width: 600px) {
		.internal-links a[href='/about'] { display: none; }
	}
</style>
